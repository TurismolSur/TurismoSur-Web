# ============================================
# SUPABASE - Base de datos y autenticación
# ============================================
# Obtén estos valores desde: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ CRÍTICO: Service Role Key (con permisos de administración)
# NO compartir ni exponer. Solo para Server-Side.
# Obtener desde: Project Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# JWT - Tokens de autenticación
# ============================================
# Generar con: openssl rand -base64 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
